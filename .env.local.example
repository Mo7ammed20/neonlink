ADMIN_PASSWORD=ChangeMe123!

# ----- Rate Limiting -----
RATE_LIMIT_WINDOW=60        # seconds
RATE_LIMIT_MAX_REQUESTS=20  # per window per IP

# ----- Analytics -----
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX   # Google Analytics (optional)
