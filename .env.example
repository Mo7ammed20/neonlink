# =============================================================
# NeonLink — Environment Variables
# =============================================================
# Copy this file to .env.local and fill in your values

# ----- App -----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=NeonLink
NODE_ENV=development

# ----- Database (PostgreSQL) -----
DATABASE_URL="postgresql://neonlink:password@localhost:5432/neonlink?schema=public"

# ----- Redis -----
REDIS_URL="redis://localhost:6379"
# Optional: Redis with password
# REDIS_URL="redis://:password@localhost:6379"

# ----- NextAuth -----
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-super-secret-key-change-this-in-production-min-32-chars

# ----- OAuth (optional) -----
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ----- Email (SMTP) -----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="NeonLink <noreply@neonlink.io>"

# ----- Geolocation -----
# Get a free key at https://ipinfo.io
IPINFO_TOKEN=your-ipinfo-token

# ----- Admin -----
ADMIN_EMAIL=admin@neonlink.io
ADMIN_PASSWORD=ChangeMe123!

# ----- Rate Limiting -----
RATE_LIMIT_WINDOW=60        # seconds
RATE_LIMIT_MAX_REQUESTS=20  # per window per IP

# ----- Analytics -----
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX   # Google Analytics (optional)
